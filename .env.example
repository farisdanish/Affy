# ==========================================
# BACKEND VARIABLES (Node/Express Server)
# ==========================================

# Port for the Express server to run on locally (default: 5000)
PORT=5000

# Your MongoDB Atlas Connection String
# DO NOT put real database passwords here!
MONGO_URI="mongodb+srv://<username>:<password>@cluster0.abcde.mongodb.net/affydb?retryWrites=true&w=majority"

# Secret key used for signing JWT tokens
# Use any random string for local development
JWT_SECRET="your-jwt-secret-here"

# Optional token to protect /healthz from random public hits
# If set, clients must send it via `x-healthz-token` header (recommended)
# or as query parameter: /healthz?token=...
HEALTHZ_TOKEN="your-healthz-token-here"


# ==========================================
# FRONTEND VARIABLES (React / Create React App)
# Note: CRA requires custom env vars to start with REACT_APP_
# ==========================================

# Points the React app to your local Express server
REACT_APP_API_URL="http://localhost:5000"

# ==========================================
# REFERRAL LINKS
# ==========================================

# Public base URL used to generate referral booking links (no trailing slash)
# Local: http://localhost:3000
# Production: https://affy-three.vercel.app
APP_PUBLIC_URL="http://localhost:3000"
